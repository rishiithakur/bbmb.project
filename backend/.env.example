# BBMB Dam Water Level Monitoring System - Django Backend Environment Variables

# Django Security Key - generate a unique random string in production
SECRET_KEY="your-production-secret-key-change-this"

# Debug mode - set to False in production
DEBUG=False

# Hostnames allowed to connect to Django (comma-separated, no spaces)
ALLOWED_HOSTS="bbmb-backend.onrender.com,localhost,127.0.0.1"

# CORS origins allowed to access Django API (comma-separated, no spaces)
CORS_ALLOWED_ORIGINS="https://bbmb-monitoring.vercel.app,http://localhost:5173"

# Database Connection URL - e.g. Neon, AWS RDS, Supabase, Render PostgreSQL
DATABASE_URL="postgresql://db_user:db_password@db_host:5432/db_name"
